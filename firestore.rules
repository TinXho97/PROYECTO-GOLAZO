rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == "jose.exe.munoz@gmail.com"
      );
    }

    // Pitches: Anyone can read, only admin can write
    match /pitches/{pitchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bookings: Anyone can read/create, only admin or owner can update/delete
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true; // In a real app, we might want to restrict this
      allow update, delete: if isAdmin();
    }

    // Users: Only owner or admin can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
  }
}
